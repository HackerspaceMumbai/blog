---
import { Image } from 'astro:assets';

export interface EventGalleryProps {
  eventTitle: string;
  eventSlug: string;
  images: Array<{ src: any; alt: string }>;
  breadcrumb: Array<{ label: string; href: string }>;
  backLink?: { label: string; href: string };
}

const {
  eventTitle,
  eventSlug,
  images = [],
  breadcrumb = [],
  backLink,
} = Astro.props;

// Validate images array
const validImages = Array.isArray(images) ? images : [];
const hasImages = validImages.length > 0;
---

<section
  class="py-12 sm:py-16 lg:py-20 px-4 bg-base-100"
  aria-labelledby="gallery-title"
>
  <div class="max-w-6xl mx-auto">
    <!-- Breadcrumb Navigation -->
    {breadcrumb.length > 0 && (
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm flex-wrap">
          {breadcrumb.map((item, index) => (
            <li key={`${item.href}-${item.label}`} class="flex items-center gap-2">
              {index > 0 && (
                <svg
                  class="w-4 h-4 text-base-content/60"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
              )}
              <a
                href={item.href}
                class={`hover:underline focus:outline-none focus:ring-2 focus:ring-primary rounded px-1 ${
                  index === breadcrumb.length - 1
                    ? 'text-base-content font-medium'
                    : 'text-primary hover:text-primary-focus'
                }`}
                aria-current={index === breadcrumb.length - 1 ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <!-- Page Header -->
    <header class="mb-12 text-center">
      <h1
        id="gallery-title"
        class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 text-primary"
      >
        {eventTitle} Gallery
      </h1>
      <p class="text-lg text-base-content/70 max-w-2xl mx-auto">
        Photos from the event
      </p>
    </header>

    <!-- Gallery Grid or Empty State -->
    {hasImages ? (
      <>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 mb-12"
          role="region"
          aria-label={`${validImages.length} photo${validImages.length === 1 ? '' : 's'} from ${eventTitle}`}
        >
          {validImages.map((image, index) => (
            <div
              key={index}
              class="group bg-base-200 border border-primary/20 rounded-lg overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
            >
              <div class="aspect-square overflow-hidden">
                <Image
                  src={image.src}
                  alt={image.alt}
                  widths={[300, 400, 500]}
                  sizes="(max-width: 640px) 300px, (max-width: 1024px) 400px, 500px"
                  width={500}
                  height={500}
                  format="webp"
                  quality={80}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            </div>
          ))}
        </div>
      </>
    ) : (
      <div
        class="text-center py-16"
        role="status"
        aria-live="polite"
      >
        <div class="mb-4">
          <svg
            class="w-16 h-16 mx-auto text-base-content/40"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-base-content mb-2">No photos yet</h2>
        <p class="text-base-content/70">
          Photos from this event will appear here soon. Check back later!
        </p>
      </div>
    )}

    <!-- Back Button -->
    {backLink && (
      <div class="text-center mt-12">
        <a
          href={backLink.href}
          class="btn btn-outline btn-primary"
          aria-label={`${backLink.label} from ${eventTitle} gallery`}
        >
          ← {backLink.label}
        </a>
      </div>
    )}
  </div>
</section>
