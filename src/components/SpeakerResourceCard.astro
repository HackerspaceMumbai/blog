---
// SpeakerResourceCard.astro: Renders a single speaker resource card

export interface SpeakerResourceCardProps {
  speakerName: string;
  resourceTitle: string;
  resourceUrl: string;
  resourceType: "slides" | "video" | "recording" | "documentation" | "blog" | "github" | "other";
  description?: string;
}

const { speakerName, resourceTitle, resourceUrl, resourceType, description } = Astro.props;

// Map resource types to icons and colors
const resourceConfig = {
  slides: { icon: "presentation", color: "text-blue-500", label: "Slides" },
  video: { icon: "play", color: "text-red-500", label: "Video" },
  recording: { icon: "video", color: "text-purple-500", label: "Recording" },
  documentation: { icon: "document", color: "text-green-500", label: "Documentation" },
  blog: { icon: "post", color: "text-amber-500", label: "Blog Post" },
  github: { icon: "github", color: "text-gray-700 dark:text-gray-300", label: "GitHub" },
  other: { icon: "link", color: "text-gray-600", label: "Resource" },
};

const config = resourceConfig[resourceType];

const iconSVGs: Record<string, string> = {
  presentation: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4a1 1 0 011 1v6a1 1 0 01-1 1H5a2 2 0 01-2-2V5a2 2 0 012-2h2zm0 0a1 1 0 001-1V3a1 1 0 00-1-1H5a1 1 0 00-1 1v1a1 1 0 001 1h2zM12 4a1 1 0 011 1v6a1 1 0 01-1 1h-2a2 2 0 01-2-2V5a2 2 0 012-2h2zm0 0a1 1 0 001-1V3a1 1 0 00-1-1h-2a1 1 0 00-1 1v1a1 1 0 001 1h2z"/>',
  play: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>',
  video: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10H3a2 2 0 00-2 2v6a2 2 0 002 2h12a2 2 0 002-2v-6a2 2 0 00-2-2z"/>',
  document: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>',
  post: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>',
  github: '<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>',
  link: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>'
};
---

<div 
  class="resource-card group flex gap-4 p-4 rounded-lg border border-base-300 bg-base-50 hover:bg-base-100 hover:border-primary/50 hover:shadow-md transition-all duration-200"
  role="article"
  aria-label={`${resourceType}: ${resourceTitle} by ${speakerName}`}
>
  <!-- Resource Type Icon -->
  <div class={`flex-shrink-0 flex items-start justify-center w-12 h-12 rounded-lg bg-base-200 group-hover:bg-primary/10 transition-colors ${config.color}`}>
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <Fragment set:html={iconSVGs[config.icon]} />
    </svg>
  </div>

  <!-- Resource Content -->
  <div class="flex-grow min-w-0">
    <div class="flex items-start gap-2 mb-1">
      <span class="inline-block px-2 py-0.5 text-xs font-semibold rounded-full bg-primary/10 text-primary flex-shrink-0">
        {config.label}
      </span>
    </div>
    
    <h4 class="font-semibold text-base-content text-base mb-1 line-clamp-2 group-hover:text-primary transition-colors">
      {resourceTitle}
    </h4>
    
    <p class="text-sm text-base-content/60 mb-2">
      By <span class="font-medium">{speakerName}</span>
    </p>
    
    {description && (
      <p class="text-sm text-base-content/70 mb-3 line-clamp-2">
        {description}
      </p>
    )}
    
    <!-- Link -->
    <a 
      href={resourceUrl} 
      target="_blank" 
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary-focus hover:underline transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded px-1"
      aria-label={`Open ${resourceTitle} (opens in new window)`}
    >
      View Resource
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-4-6l6 6m0 0l-6 6" />
      </svg>
    </a>
  </div>
</div>

