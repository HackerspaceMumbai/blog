---
import CTAButton from './CTAButton.astro';
import SectionHeading from './SectionHeading.astro';
---
<section id="join" class="py-12 sm:py-16 lg:py-20 px-4 bg-base-100 text-base-content" aria-labelledby="join-heading" role="region">
  <div class="max-w-6xl mx-auto">
    <!-- Enhanced section header -->
    <div class="text-center mb-10 sm:mb-14 lg:mb-16">
      <SectionHeading 
        id="join" 
        level={2}
        class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-3 sm:mb-4 text-primary"
      >
        Get Involved
      </SectionHeading>
      <p class="text-sm sm:text-base lg:text-lg text-base-content/70 max-w-2xl mx-auto leading-relaxed">
        Choose how you'd like to contribute to Mumbai's largest open source community
      </p>
    </div>
    
    <!-- Mobile-optimized grid layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 lg:gap-10">
      <!-- Join Community Card -->
      <div class="group card bg-base-200 border border-primary p-5 sm:p-6 lg:p-7 rounded-xl flex flex-col hover:shadow-lg hover:border-primary/80 hover:-translate-y-1 transition-all duration-300">
        <!-- Card header with icon -->
        <div class="flex items-center mb-4">
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mr-3 group-hover:bg-primary/20 transition-colors">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl lg:text-2xl font-bold text-primary">Join Our Community</h3>
        </div>
        
  <p class="mb-6 sm:mb-7 text-sm sm:text-base leading-relaxed text-base-content/80 min-h-[88px]">
          Connect with like-minded developers and stay updated on events, projects, and opportunities.
        </p>
        
  <div class="flex flex-col gap-3 sm:gap-4 w-full">
          <CTAButton 
            href="https://www.linkedin.com/company/hackerspace-mumbai/" 
            variant="primary" 
            target="_blank"
            fullWidth={true}
            icon="left"
            aria-label="Join us on LinkedIn (opens in new window)"
          >
            <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.11 1 2.5 1s2.48 1.12 2.48 2.5ZM.5 8h4V23h-4V8Zm7 0h3.83v2.05h.05c.53-1.01 1.84-2.08 3.79-2.08 4.05 0 4.8 2.67 4.8 6.14V23h-4v-7.82c0-1.87-.03-4.27-2.6-4.27-2.6 0-3 2.03-3 4.13V23h-4V8Z"/>
            </svg>
            Join us on LinkedIn
          </CTAButton>
          <CTAButton 
            href="https://www.meetup.com/mumbai-technology-meetup/" 
            variant="primary" 
            target="_blank"
            fullWidth={true}
            icon="left"
            aria-label="Join us on Meetup (opens in new window)"
          >
            <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M20.66 7.24c-.69-.3-1.58-.24-2.12.53l-1.7 2.42-.77-1.44c-.45-.84-1.64-.93-2.21-.18l-2.95 3.9.88-6.62c.14-1.08-.62-1.85-1.55-1.85-.77 0-1.42.47-1.67 1.42L5.67 15.53l-.8-1.5c-.52-.98-1.98-.85-2.32.2l-1.78 5.5c-.2.64.15 1.33.79 1.54.64.2 1.33-.15 1.54-.79l1.01-3.12.94 1.76c.52.98 1.97.86 2.32-.19l2.56-7.71-.78 5.91c-.14 1.09.62 1.86 1.55 1.86.53 0 1.08-.24 1.45-.74l3.75-4.96.69 1.29c.44.82 1.58.93 2.18.23l3.2-3.64c.44-.5.39-1.27-.11-1.71-.16-.14-.35-.24-.55-.32Z"/>
            </svg>
            Join us on Meetup
          </CTAButton>
          <CTAButton 
            href="#newsletter" 
            variant="primary"
            fullWidth={true}
            icon="left"
            aria-label="Navigate to newsletter signup section"
          >
            <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
              <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"></path>
                <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"></path>
              </svg>
            </svg>
            Join Mailing List
          </CTAButton>
        </div>
      </div>
      
      <!-- Contribute Card -->
      <div class="group card bg-base-200 border border-primary p-5 sm:p-6 lg:p-7 rounded-xl flex flex-col hover:shadow-lg hover:border-primary/80 hover:-translate-y-1 transition-all duration-300">
        <!-- Card header with icon -->
        <div class="flex items-center mb-4">
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mr-3 group-hover:bg-primary/20 transition-colors">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
              </svg>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl lg:text-2xl font-bold text-primary">Contribute</h3>
        </div>
        
  <p class="mb-6 sm:mb-7 text-sm sm:text-base leading-relaxed text-base-content/80 min-h-[88px]">
          Make a difference by contributing to our open source projects and community initiatives.
        </p>
        
  <div class="flex flex-col gap-3 sm:gap-4 w-full">
          <CTAButton 
            href="https://github.com/HackerspaceMumbai" 
            variant="primary" 
            target="_blank"
            fullWidth={true}
            icon="left"
            aria-label="View our GitHub projects (opens in new window)"
          >
            <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
              <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
              </svg>
            </svg>
            GitHub Projects
          </CTAButton>
          <CTAButton 
            href="https://github.com/HackerspaceMumbai/HackerspaceMumbai/blob/master/CODE_OF_CONDUCT.md" 
            variant="primary"
            fullWidth={true}
            icon="left"
            target="_blank"
            aria-label="Read our code of conduct (opens in new window)"
          >
            <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
              <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M11.7 2.805a.75.75 0 01.6 0A60.65 60.65 0 0122.83 8.72a.75.75 0 01-.231 1.337 49.949 49.949 0 00-9.902 3.912l-.003.002-.34.18a.75.75 0 01-.707 0A50.009 50.009 0 007.5 12.174v-.224c0-.131.067-.248.172-.311a54.614 54.614 0 014.653-2.52.75.75 0 00-.65-1.352 56.129 56.129 0 00-4.78 2.589 1.858 1.858 0 00-.859 1.228 49.803 49.803 0 00-4.634-1.527.75.75 0 01-.231-1.337A60.653 60.653 0 0111.7 2.805z"></path>
                <path d="M13.06 15.473a48.45 48.45 0 017.666-3.282c.134 1.414.22 2.843.255 4.285a.75.75 0 01-.46.71 47.878 47.878 0 00-8.105 4.342.75.75 0 01-.832 0 47.877 47.877 0 00-8.104-4.342.75.75 0 01-.461-.71c.035-1.442.121-2.87.255-4.286A48.4 48.4 0 016 13.18v1.27a1.5 1.5 0 00-.14 2.508c-.09.38-.222.753-.397 1.11.452.213.901.434 1.346.661a6.729 6.729 0 00.551-1.608 1.5 1.5 0 00.14-2.67v-.645a48.549 48.549 0 013.44 1.668 2.25 2.25 0 002.12 0z"></path>
                <path d="M4.462 19.462c.42-.419.753-.89 1-1.394.453.213.902.434 1.347.661a6.743 6.743 0 01-1.286 1.794.75.75 0 11-1.06-1.06z"></path>
              </svg>
            </svg>
            Code of Conduct
          </CTAButton>
        </div>
      </div>
      
      <!-- Speak & Volunteer Card -->
      <div class="group card bg-base-200 border border-primary p-5 sm:p-6 lg:p-7 rounded-xl flex flex-col hover:shadow-lg hover:border-primary/80 hover:-translate-y-1 transition-all duration-300 md:col-span-2 lg:col-span-1">
        <!-- Card header with icon -->
        <div class="flex items-center mb-4">
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mr-3 group-hover:bg-primary/20 transition-colors">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.25 4.5a3.75 3.75 0 117.5 0v8.25a3.75 3.75 0 11-7.5 0V4.5z"/>
              <path d="M6 10.5a.75.75 0 01.75.75v1.5a5.25 5.25 0 1010.5 0v-1.5a.75.75 0 011.5 0v1.5a6.751 6.751 0 01-6 6.709v2.291h3a.75.75 0 010 1.5h-7.5a.75.75 0 010-1.5h3v-2.291a6.751 6.751 0 01-6-6.709v-1.5A.75.75 0 016 10.5z"/>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl lg:text-2xl font-bold text-primary">Speak & Volunteer</h3>
        </div>
        
  <p class="mb-6 sm:mb-7 text-sm sm:text-base leading-relaxed text-base-content/80 min-h-[88px]">
          Share your knowledge as a speaker or help organize our events as a volunteer.
        </p>
        
  <div class="flex flex-col gap-3 sm:gap-4 w-full">
          <CTAButton 
            href="/speak" 
            variant="primary"
            fullWidth={true}
            icon="left"
            aria-label="Apply to become a speaker"
          >
            <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.25 4.5a3.75 3.75 0 117.5 0v8.25a3.75 3.75 0 11-7.5 0V4.5z"/>
              <path d="M6 10.5a.75.75 0 01.75.75v1.5a5.25 5.25 0 1010.5 0v-1.5a.75.75 0 011.5 0v1.5a6.751 6.751 0 01-6 6.709v2.291h3a.75.75 0 010 1.5h-7.5a.75.75 0 010-1.5h3v-2.291a6.751 6.751 0 01-6-6.709v-1.5A.75.75 0 016 10.5z"/>
            </svg>
            Become a Speaker
          </CTAButton>
          <CTAButton 
            href="/volunteer" 
            variant="primary"
            fullWidth={true}
            icon="left"
            aria-label="Apply to volunteer with us"
          >
            <svg slot="icon-left" class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M4.5 6.375a4.125 4.125 0 118.25 0 4.125 4.125 0 01-8.25 0zM14.25 8.625a3.375 3.375 0 116.75 0 3.375 3.375 0 01-6.75 0zM1.5 19.125a7.125 7.125 0 0114.25 0v.003l-.001.119a.75.75 0 01-.363.63 13.067 13.067 0 01-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 01-.364-.63l-.001-.122zM17.25 19.128l-.001.144a2.25 2.25 0 01-.233.96 10.088 10.088 0 005.06-1.01.75.75 0 00.42-.643 4.875 4.875 0 00-6.957-4.611 8.586 8.586 0 011.71 5.157v.003z"/>
            </svg>
            Volunteer with Us
          </CTAButton>
        </div>
      </div>
    </div>
    
    <!-- Mobile-friendly bottom engagement section -->
    <div class="mt-12 sm:mt-16 lg:mt-20 text-center">
      <div class="bg-base-300/50 rounded-2xl p-6 sm:p-8 lg:p-10 border border-primary/20">
        <h3 class="text-lg sm:text-xl lg:text-2xl font-bold text-primary mb-3 sm:mb-4">
          Not Sure Where to Start?
        </h3>
        <p class="text-sm sm:text-base text-base-content/70 mb-6 sm:mb-8 max-w-2xl mx-auto leading-relaxed">
          Reach out to us directly and we'll help you find the perfect way to get involved with Mumbai's tech community.
        </p>
        
        <!-- Contact options with mobile-optimized layout -->
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center items-center max-w-lg mx-auto">
          <CTAButton 
            href="mailto:hello@hackmum.in" 
            variant="outline"
            size="lg"
            aria-label="Contact us via email"
            extraClass="shadow-sm hover:shadow-md flex-1 sm:flex-none"
          >
            <span class="flex items-center justify-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </svg>
              Email Us
            </span>
          </CTAButton>
          
          <CTAButton 
            href="https://twitter.com/hackmum" 
            variant="outline"
            size="lg"
            target="_blank"
            aria-label="Follow us on Twitter (opens in new window)"
            extraClass="shadow-sm hover:shadow-md flex-1 sm:flex-none"
          >
            <span class="flex items-center justify-center">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
              </svg>
              Follow Us
            </span>
          </CTAButton>
        </div>
        
        <!-- Quick stats for mobile engagement -->
        <div class="mt-8 sm:mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 max-w-2xl mx-auto">
          <div class="text-center">
            <div class="text-xl sm:text-2xl font-bold text-primary">5000+</div>
            <div class="text-xs sm:text-sm text-base-content/60">Members</div>
          </div>
          <div class="text-center">
            <div class="text-xl sm:text-2xl font-bold text-primary">120+</div>
            <div class="text-xs sm:text-sm text-base-content/60">Events</div>
          </div>
          <div class="text-center">
            <div class="text-xl sm:text-2xl font-bold text-primary">30+</div>
            <div class="text-xs sm:text-sm text-base-content/60">Projects</div>
          </div>
          <div class="text-center">
            <div class="text-xl sm:text-2xl font-bold text-primary">14+</div>
            <div class="text-xs sm:text-sm text-base-content/60">Years</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
