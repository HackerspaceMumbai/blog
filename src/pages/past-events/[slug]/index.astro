---
import Layout from "../../../components/Layout.astro";
import PastEventCard from "../../../components/PastEventCard.astro";
import { getCollection } from "astro:content";

// Fetch all past events for static route generation
const pastEventCollection = await getCollection("pastEvents");

export async function getStaticPaths() {
  const pastEvents = await getCollection("pastEvents");
  return pastEvents.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

interface Props {
  event: (typeof pastEventCollection)[0];
}

const { event } = Astro.props;
const { slug } = Astro.params;

const title = `${event.data.title} - Past Event - Hackerspace Mumbai`;
const description = event.data.description;
const canonical = `https://hackmum.in/past-events/${slug}`;
---

<Layout
  title={title}
  description={description}
  tags={["past events", "meetups", "speaker resources", slug ?? "event"]}
  canonical={canonical}
  type="article"
>
  <h1 class="sr-only">{event.data.title}</h1>

  <!-- Hero-like section with breadcrumb -->
  <div class="bg-gradient-to-b from-primary/10 to-base-100 py-8 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm">
          <li>
            <a href="/" class="text-primary hover:text-primary-focus hover:underline focus:outline-none focus:ring-2 focus:ring-primary rounded px-1">
              Home
            </a>
          </li>
          <li class="text-base-content/60">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </li>
          <li>
            <a href="/past-events" class="text-primary hover:text-primary-focus hover:underline focus:outline-none focus:ring-2 focus:ring-primary rounded px-1">
              Past Events
            </a>
          </li>
          <li class="text-base-content/60">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </li>
          <li class="text-base-content font-medium" aria-current="page">
            {event.data.title}
          </li>
        </ol>
      </nav>
    </div>
  </div>

  <section class="py-12 sm:py-16 px-4 bg-base-100 text-base-content" aria-labelledby="past-event-title">
    <div class="max-w-5xl mx-auto">
      <PastEventCard
        title={event.data.title}
        date={event.data.date}
        location={event.data.location}
        description={event.data.description}
        speakerResources={event.data.speakerResources}
        coverImage={event.data.coverImage}
        eventId={event.id}
        slug={event.slug}
      />

      <div class="text-center mt-10">
        <a href="/past-events" class="btn btn-outline btn-primary">← Back to Past Events</a>
      </div>
    </div>
  </section>
</Layout>
